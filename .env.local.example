# Copy this file to `.env.local` and fill in real values.
# .env.local is git-ignored — never commit real keys.

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://hatqqguxdezdhlocffqc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-anon-key-from-supabase-dashboard>

# ── Optional: service role key (server-only, never NEXT_PUBLIC) ─
# Used by Edge Functions and server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key-from-supabase-dashboard>

# ── Web Push (phone notifications) ────────────────────────
# Public VAPID key — safe to expose to the browser. The matching private key
# lives only in the dispatch-notification Edge Function's secrets.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<paste-vapid-public-key>
