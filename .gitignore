# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (contains secrets!)
.env*.local
.env

# vercel
.vercel

# netlify (local CLI state)
.netlify

# claude code local settings
.claude

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local
supabase/.branches
supabase/.temp
